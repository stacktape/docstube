---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import VerifierCascade from '../components/VerifierCascade.astro';
import CodeWindow from '../components/CodeWindow.astro';
import RunsOn from '../components/RunsOn.astro';
import Steps from '../components/Steps.astro';
import Pillars from '../components/Pillars.astro';
import DriftReport from '../components/DriftReport.astro';
import Pricing from '../components/Pricing.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Tabs from '../components/Tabs.astro';
import { site, facts } from '../data/site.ts';

// Illustrative mock data - clearly labelled as such in the UI below.
const navTree = [
  { label: 'Getting started', depth: 0, kind: 'group' },
  { label: 'Installation', depth: 1, kind: 'page' },
  { label: 'Quickstart', depth: 1, kind: 'page' },
  { label: 'Core concepts', depth: 0, kind: 'group' },
  { label: 'Configuration', depth: 1, kind: 'page' },
  { label: 'API reference', depth: 0, kind: 'page' }
];

const genTimeline = [
  { page: 'getting-started/installation', state: 'pass' },
  { page: 'getting-started/quickstart', state: 'pass' },
  { page: 'core-concepts/configuration', state: 'pass' },
  { page: 'guides/authentication', state: 'run' },
  { page: 'reference/api', state: 'wait' },
  { page: 'guides/migration', state: 'flag' }
];
---

<Base
  title="docstube - point it at your repo, watch it build"
  description="Run docstube wizard and a localhost web UI opens. Pick a doc type, define your reader personas, add a little context - then watch a verified docs site assemble itself, page by page. Open source, bring your own AI."
  variant="v8 · the wizard flow"
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="grid-bg relative overflow-hidden border-b border-line">
      <div class="glow relative mx-auto grid max-w-6xl items-center gap-12 px-5 py-20 sm:px-8 lg:grid-cols-[1fr_1.05fr] lg:py-28">
        <div class="relative z-10 flex flex-col items-start gap-6">
          <span class="eyebrow">One command · live web UI</span>
          <h1 class="text-5xl font-extrabold sm:text-[64px] sm:leading-[0.98]">
            Point it at your repo. <span class="gradient-text">Watch.</span>
          </h1>
          <p class="max-w-xl text-[18px] leading-relaxed text-muted">
            Run <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-[15px] text-brand-700">docstube wizard</code>
            and a local web UI opens. Pick a doc type, define your reader personas, add a little context - then watch a
            verified site assemble itself, page by page.
          </p>

          <!-- Install command, front and center -->
          <div class="w-full max-w-md">
            <div class="terminal">
              <div class="terminal-bar">
                <span class="terminal-dot" style="background:#f0716b"></span>
                <span class="terminal-dot" style="background:#f3c64a"></span>
                <span class="terminal-dot" style="background:#54c98b"></span>
                <span class="ml-2 font-mono text-[12px] text-[#6f8e8a]">~/your-repo</span>
              </div>
              <div class="px-4 py-3.5 font-mono text-[13.5px] leading-relaxed">
                <span class="text-[#5fb8a8]">$</span>
                <span class="text-[#e6f6f2]"> {site.install}</span>
                <span class="caret text-[#5fd0bb]">▋</span>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row">
            <a href={site.repo} class="btn btn-primary">Try it on your repo</a>
            <a href="#flow" class="btn btn-secondary">See a run</a>
          </div>
          <div class="flex items-center gap-4 font-mono text-[12.5px] text-muted">
            <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-pass"></span> MIT licensed</span>
            <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-brand-400"></span> bring your own AI</span>
            <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-brand-400"></span> source stays local</span>
          </div>
        </div>

        <!-- Hero: localhost opening, with a sense of motion -->
        <div class="relative z-10 float-slow">
          <div class="terminal">
            <div class="terminal-bar">
              <span class="terminal-dot" style="background:#f0716b"></span>
              <span class="terminal-dot" style="background:#f3c64a"></span>
              <span class="terminal-dot" style="background:#54c98b"></span>
              <span class="ml-2 font-mono text-[12px] text-[#6f8e8a]">docstube wizard</span>
              <span class="ml-auto font-mono text-[11px] text-[#4d6b67]">live</span>
            </div>
            <div class="space-y-1.5 px-4 py-4 font-mono text-[12.5px] leading-relaxed sm:px-5">
              <div class="cascade-row" style="animation-delay:.05s">
                <span class="text-[#5fb8a8]">$</span> <span class="text-[#e6f6f2]">{site.install}</span>
              </div>
              <div class="cascade-row text-[#7f9d99]" style="animation-delay:.45s">
                ▸ scanning repository · tree-sitter codemap
              </div>
              <div class="cascade-row text-[#7f9d99]" style="animation-delay:.85s">
                ▸ detected agent: <span class="text-[#9bd9cb]">claude</span> (your subscription)
              </div>
              <div class="cascade-row" style="animation-delay:1.25s">
                <span class="text-[#5fd0bb]">✓</span> <span class="text-[#cfeae6]">local control plane ready</span>
              </div>
              <div class="cascade-row text-[#e6f6f2]" style="animation-delay:1.65s">
                ◴ opening <span class="text-[#7fe0cd]">http://localhost:4321</span> …
              </div>
              <div class="cascade-row mt-2.5 rounded-lg border border-[#1f4641] bg-[#0c1f1d] px-3 py-2" style="animation-delay:2.05s">
                <div class="flex items-center gap-2 text-[11px] text-[#7f9d99]">
                  <span class="h-2 w-2 rounded-full bg-[#5fd0bb]" style="animation: floaty 1.4s ease-in-out infinite"></span>
                  wizard ui · waiting for your input
                </div>
                <div class="mt-2 flex items-center gap-2">
                  <span class="rounded bg-[#15302d] px-2 py-1 text-[11px] text-[#9bd9cb]">doc type</span>
                  <span class="rounded bg-[#15302d] px-2 py-1 text-[11px] text-[#9bd9cb]">personas</span>
                  <span class="rounded bg-[#15302d] px-2 py-1 text-[11px] text-[#9bd9cb]">nav tree</span>
                </div>
              </div>
            </div>
          </div>
          <p class="mt-3 text-center font-mono text-[11px] text-muted">Illustrative - not a screenshot.</p>
        </div>
      </div>
    </section>

    <div class="border-b border-line bg-paper py-12">
      <RunsOn heading="Runs on the AI you already pay for" />
    </div>

    <!-- Signature section: walk the journey with Tabs -->
    <Section
      id="flow"
      eyebrow="The run, end to end"
      title="Four steps. You drive the first one - it does the rest."
      intro="From npx to a site you own. Walk each step of a real run below."
    >
      <Tabs tabs={['1 · Wizard', '2 · Generate', '3 · Review', '4 · Refresh']}>
        <!-- Step 1: Wizard setup card -->
        <div slot="panel-0" class="grid items-start gap-8 lg:grid-cols-[1fr_0.95fr]">
          <div class="surface overflow-hidden">
            <div class="flex items-center justify-between border-b border-line bg-canvas px-5 py-3">
              <span class="font-mono text-[12px] text-muted">localhost:4321 · setup</span>
              <span class="chip text-[11px]">illustrative</span>
            </div>
            <div class="space-y-6 p-6">
              <div>
                <p class="eyebrow mb-2.5">Doc type</p>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-lg border border-brand-300 bg-brand-50 px-3 py-1.5 text-[13px] font-medium text-brand-700">Public docs site</span>
                  <span class="rounded-lg border border-line px-3 py-1.5 text-[13px] text-muted">Internal wiki</span>
                  <span class="rounded-lg border border-line px-3 py-1.5 text-[13px] text-muted">API reference</span>
                </div>
              </div>

              <div>
                <p class="eyebrow mb-2.5">Reader personas</p>
                <div class="space-y-2">
                  <div class="flex items-center gap-3 rounded-lg border border-line bg-paper px-3 py-2">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-[11px] font-bold text-brand-700">N</span>
                    <span class="text-[13.5px] text-ink-soft">New integrator <span class="text-muted">· wants the 5-minute path</span></span>
                  </div>
                  <div class="flex items-center gap-3 rounded-lg border border-line bg-paper px-3 py-2">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-[11px] font-bold text-brand-700">P</span>
                    <span class="text-[13.5px] text-ink-soft">Platform engineer <span class="text-muted">· depth, edge cases, config</span></span>
                  </div>
                  <button type="button" class="text-[13px] font-medium text-brand-600">+ add persona</button>
                </div>
              </div>

              <div>
                <div class="mb-2.5 flex items-center justify-between">
                  <p class="eyebrow">Information architecture</p>
                  <span class="font-mono text-[11px] text-muted">drag to reorder</span>
                </div>
                <ul class="space-y-1">
                  {
                    navTree.map((n) => (
                      <li
                        class={`flex items-center gap-2 rounded-md py-1.5 text-[13.5px] ${n.kind === 'group' ? 'font-semibold text-ink' : 'text-ink-soft'}`}
                        style={`padding-left:${10 + n.depth * 20}px`}
                      >
                        <span class="text-muted">⋮⋮</span>
                        {n.kind === 'group' ? (
                          <span class="text-brand-500">▸</span>
                        ) : (
                          <span class="text-line-strong">•</span>
                        )}
                        <span>{n.label}</span>
                      </li>
                    ))
                  }
                  <li class="flex items-center gap-2 rounded-md py-1.5 pl-2.5 text-[13px] font-medium text-brand-600">
                    + add page
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-5">
            <h3 class="font-display text-[22px] font-semibold text-ink">You shape it. Then step back.</h3>
            <p class="text-[15px] leading-relaxed text-muted">
              The wizard proposes a nav tree from your codebase - you edit it like a list: reorder, rename, add or drop
              pages. Pick a doc type, name the people who'll read it, paste any context that isn't in the code. That's
              the whole setup. From here it runs on its own.
            </p>
            <ul class="space-y-2.5 text-[14.5px] text-ink-soft">
              <li class="flex gap-2.5"><span class="text-brand-500">→</span> Personas become per-audience reviewer agents.</li>
              <li class="flex gap-2.5"><span class="text-brand-500">→</span> The nav tree becomes the page plan you just saw.</li>
              <li class="flex gap-2.5"><span class="text-brand-500">→</span> Your source never leaves your machine.</li>
            </ul>
          </div>
        </div>

        <!-- Step 2: Generate - CI timeline + live preview -->
        <div slot="panel-1" class="grid items-start gap-8 lg:grid-cols-[1fr_0.95fr]">
          <div class="surface overflow-hidden">
            <div class="flex items-center justify-between border-b border-line bg-canvas px-5 py-3">
              <span class="font-mono text-[12px] text-muted">generating · 6 pages</span>
              <span class="chip text-[11px]">illustrative</span>
            </div>
            <ul class="divide-y divide-line">
              {
                genTimeline.map((row) => (
                  <li class="flex items-center gap-3 px-5 py-3 font-mono text-[13px]">
                    {row.state === 'pass' && (
                      <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-pass/12 text-pass">
                        <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2.5 6.2 5 8.7 9.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                    )}
                    {row.state === 'run' && (
                      <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full border-2 border-brand-200 border-t-brand-500" style="animation: spin 0.9s linear infinite"></span>
                    )}
                    {row.state === 'wait' && (
                      <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-line-strong text-[10px] text-muted">·</span>
                    )}
                    {row.state === 'flag' && (
                      <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-flag/15 text-flag">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 2.2 10.4 9.6H1.6L6 2.2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
                      </span>
                    )}
                    <span class={row.state === 'wait' ? 'text-muted' : row.state === 'flag' ? 'text-flag' : 'text-ink-soft'}>
                      {row.page}
                    </span>
                    <span class="ml-auto text-[11px] text-muted">
                      {row.state === 'pass' && 'verified'}
                      {row.state === 'run' && 'drafting…'}
                      {row.state === 'wait' && 'queued'}
                      {row.state === 'flag' && 'needs review'}
                    </span>
                  </li>
                ))
              }
            </ul>
            <div class="flex items-center gap-2 border-t border-line bg-canvas px-5 py-2.5 font-mono text-[11px] text-muted">
              <span class="h-1.5 w-1.5 rounded-full bg-pass"></span> 3 verified
              <span class="ml-3 h-1.5 w-1.5 rounded-full bg-brand-400"></span> 1 running
              <span class="ml-3 h-1.5 w-1.5 rounded-full bg-flag"></span> 1 flagged
            </div>
          </div>

          <div class="flex flex-col gap-5">
            <div class="surface overflow-hidden">
              <div class="flex items-center gap-1.5 border-b border-line bg-canvas px-4 py-2.5">
                <span class="h-2.5 w-2.5 rounded-full bg-line-strong"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-line-strong"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-line-strong"></span>
                <span class="ml-2 font-mono text-[11px] text-muted">live preview · authentication</span>
              </div>
              <div class="space-y-2.5 p-5">
                <div class="h-3 w-2/5 rounded bg-brand-100"></div>
                <div class="h-2 w-full rounded bg-line"></div>
                <div class="h-2 w-11/12 rounded bg-line"></div>
                <div class="mt-3 rounded-lg bg-night px-3 py-2.5">
                  <div class="h-2 w-1/3 rounded bg-[#2a4a46]"></div>
                  <div class="mt-1.5 h-2 w-2/3 rounded bg-[#1f3a36]"></div>
                </div>
                <div class="h-2 w-4/5 rounded bg-line"></div>
              </div>
            </div>
            <div>
              <h3 class="font-display text-[22px] font-semibold text-ink">A build log you can actually watch.</h3>
              <p class="mt-2 text-[15px] leading-relaxed text-muted">
                A writer agent drafts each page from a structural map of your source. Pages stream into the preview pane
                as they finish. The step timeline shows exactly where the run is - verified, drafting, or flagged - so
                nothing happens in a black box.
              </p>
            </div>
          </div>
        </div>

        <!-- Step 3: Review - rendered page + inline feedback -->
        <div slot="panel-2" class="grid items-start gap-8 lg:grid-cols-[1fr_0.95fr]">
          <div class="surface overflow-hidden">
            <div class="flex items-center justify-between border-b border-line bg-canvas px-5 py-3">
              <span class="font-mono text-[12px] text-muted">review · production render</span>
              <span class="chip text-[11px]">illustrative</span>
            </div>
            <div class="p-6">
              <p class="eyebrow mb-1.5">Quickstart</p>
              <h4 class="font-display text-[19px] font-semibold text-ink">Authenticate your first request</h4>
              <p class="mt-2 text-[13.5px] leading-relaxed text-muted">
                Create a client with your API key. Every call below is type-checked against the real signatures in your
                repo before this page ships.
              </p>

              <div class="relative mt-4 rounded-[14px] ring-2 ring-brand-100 ring-offset-2 ring-offset-paper">
                <CodeWindow file="quickstart.ts" lang="ts">
<span class="text-[#8fb3ad]">import</span> {'{ createClient }'} <span class="text-[#8fb3ad]">from</span> <span class="text-[#9bd9cb]">'./client.ts'</span>;

<span class="text-[#8fb3ad]">const</span> client = <span class="text-[#7fe0cd]">createClient</span>({'{'}
  apiKey: process.env.<span class="text-[#9bd9cb]">API_KEY</span>,
{'}'});
                </CodeWindow>
                <!-- inline element feedback affordance -->
                <button
                  type="button"
                  class="absolute -right-2 -top-2 z-10 inline-flex items-center gap-1.5 rounded-full border border-brand-300 bg-paper px-2.5 py-1 text-[11px] font-medium text-brand-700 shadow-soft"
                >
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2 3h8v5H6.5L4 10V8H2V3Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                  comment on this block
                </button>
              </div>

              <p class="mt-4 text-[13.5px] leading-relaxed text-muted">
                Prefer a longer walkthrough? Leave feedback on the element, the section, or the whole page - the next
                regenerate folds it in.
              </p>
            </div>
            <div class="flex flex-wrap items-center gap-2 border-t border-line bg-canvas px-5 py-3">
              <span class="mr-1 font-mono text-[11px] text-muted">feedback scope:</span>
              <span class="rounded-md border border-brand-300 bg-brand-50 px-2.5 py-1 text-[12px] font-medium text-brand-700">element</span>
              <span class="rounded-md border border-line px-2.5 py-1 text-[12px] text-muted">section</span>
              <span class="rounded-md border border-line px-2.5 py-1 text-[12px] text-muted">page</span>
              <div class="ml-auto flex items-center gap-2">
                <button type="button" class="btn btn-secondary btn-sm">Regenerate</button>
                <button type="button" class="btn btn-primary btn-sm">Approve</button>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-5">
            <h3 class="font-display text-[22px] font-semibold text-ink">Review the real page, not a diff.</h3>
            <p class="text-[15px] leading-relaxed text-muted">
              You read each page exactly as it'll render in production. Point at any element, section, or the whole page
              and leave a note - too terse, wrong audience, add an example. Approve it or send it back to regenerate
              with your feedback attached.
            </p>
            <div class="surface-tint flex items-center gap-4 p-5">
              <span class="font-display text-[36px] font-bold leading-none gradient-text">⚠</span>
              <p class="text-[14px] leading-relaxed text-ink-soft">
                Pages that can't be mechanically verified arrive
                <span class="font-semibold text-ink"> flagged, never silently wrong</span> - with the exact finding
                attached.
              </p>
            </div>
          </div>
        </div>

        <!-- Step 4: Refresh - only affected pages -->
        <div slot="panel-3" class="grid items-start gap-8 lg:grid-cols-[1fr_0.95fr]">
          <div class="flex flex-col gap-5">
            <div class="terminal">
              <div class="terminal-bar">
                <span class="terminal-dot" style="background:#f0716b"></span>
                <span class="terminal-dot" style="background:#f3c64a"></span>
                <span class="terminal-dot" style="background:#54c98b"></span>
                <span class="ml-2 font-mono text-[12px] text-[#6f8e8a]">~/your-repo</span>
              </div>
              <div class="space-y-1 px-4 py-3.5 font-mono text-[12.5px] leading-relaxed">
                <div><span class="text-[#5fb8a8]">$</span> <span class="text-[#e6f6f2]">git commit -m "refactor auth client"</span></div>
                <div><span class="text-[#5fb8a8]">$</span> <span class="text-[#e6f6f2]">docstube refresh</span></div>
                <div class="text-[#7f9d99]">▸ diffing symbols · 2 pages touch changed code</div>
                <div><span class="text-[#5fd0bb]">✓</span> <span class="text-[#cfeae6]">guides/authentication</span> <span class="text-[#7f9d99]">regenerated · verified</span></div>
                <div><span class="text-[#5fd0bb]">✓</span> <span class="text-[#cfeae6]">reference/api</span> <span class="text-[#7f9d99]">regenerated · verified</span></div>
                <div class="text-[#7f9d99]">▸ 14 unaffected pages skipped</div>
              </div>
            </div>
            <p class="text-center font-mono text-[11px] text-muted">Illustrative - not a screenshot.</p>
          </div>

          <div class="flex flex-col gap-5">
            <h3 class="font-display text-[22px] font-semibold text-ink">Change one function - refresh only what moved.</h3>
            <p class="text-[15px] leading-relaxed text-muted">
              Provenance is tracked at the symbol level, so <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-[13px] text-brand-700">docstube refresh</code>
              only regenerates the pages that actually touch the code you changed. Everything else is left untouched.
              Wire up the GitHub Action and the same run opens a PR with the changed pages - and the reasons why.
            </p>
            <DriftReport />
          </div>
        </div>
      </Tabs>
    </Section>

    <!-- Verification -->
    <Section
      id="verify"
      eyebrow="Before any page ships"
      title="Mechanically checked, not vibe-checked."
      intro="Persona reviewers judge audience fit. But the gate every page must clear is deterministic - the same tools you'd run in CI, run against the docs."
      tone="paper"
    >
      <div class="grid items-center gap-10 lg:grid-cols-[1fr_0.85fr]">
        <div class="relative">
          <VerifierCascade caption="Live verifier pass · illustrative" />
        </div>
        <div class="flex flex-col gap-5">
          <p class="text-[15px] leading-relaxed text-muted">
            Every code sample type-checks. Every import resolves. Every API reference is matched against your real
            compiler signatures. Diagrams render. Links work. A page that can't pass retries with the finding, or ships
            clearly flagged for a human.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="chip">tsc</span>
            <span class="chip">pyright</span>
            <span class="chip">link check</span>
            <span class="chip">D2 render</span>
            <span class="chip">API signatures</span>
          </div>
        </div>
      </div>
    </Section>

    <!-- Always current -->
    <Section
      eyebrow="Stays in sync"
      title="Generate, review, verify - then it keeps itself current."
      intro="The first run is the wizard. Every run after is automatic."
    >
      <Steps />
    </Section>

    <!-- Pillars -->
    <Section eyebrow="Why this run is different" title="Four things most doc tools skip." tone="paper">
      <Pillars columns={4} />
    </Section>

    <!-- Repo scale note (sourced fact) -->
    <Section>
      <div class="surface-tint mx-auto flex max-w-3xl flex-col items-center gap-3 p-8 text-center">
        <p class="font-display text-[40px] font-bold leading-none gradient-text">{facts.reposPerMinute.stat}</p>
        <p class="text-[16px] leading-relaxed text-ink-soft">
          new repositories {facts.reposPerMinute.claim}. Every one of them will need docs that keep up with the code.
        </p>
        <p class="font-mono text-[11.5px] text-muted">Source: {facts.reposPerMinute.source}</p>
      </div>
    </Section>

    <!-- Pricing -->
    <Section
      id="pricing"
      eyebrow="Pricing"
