---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/Section.astro';
import Steps from '../components/Steps.astro';
import DriftReport from '../components/DriftReport.astro';
import UseCases from '../components/UseCases.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Pricing from '../components/Pricing.astro';
import CompareTable from '../components/CompareTable.astro';
import BuiltForAgents from '../components/BuiltForAgents.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import RunsOn from '../components/RunsOn.astro';
import { site } from '../data/site.ts';

// Illustrative provenance flow for the hero. Clearly a mock - labelled "example".
const affected = [
  { page: 'api/create-session.mdx', why: 'documents getSession()' },
  { page: 'guides/authentication.mdx', why: 'shows a getSession() sample' }
];
const unchanged = ['guides/quickstart.mdx', 'reference/errors.mdx', 'guides/webhooks.mdx'];

// Illustrative PR card the GitHub Action opens. Not a real PR.
const prPages = [
  { file: 'api/create-session.mdx', reason: 'getSession() signature changed' },
  { file: 'guides/authentication.mdx', reason: 'sample updated to new return type' },
  { file: 'reference/sessions.mdx', reason: 'API reference re-extracted from compiler' }
];
---

<Base
  title="docstube - documentation that keeps up with your code"
  description="Change a function and only the pages it touches regenerate, tracked at the symbol level. Run docstube refresh locally or as a GitHub Action that opens a PR with the changed pages and the reasons why - never pushed silently. Open source, MIT, your code stays on your machine."
  variant="v10 · always current"
>
  <Header />

  <main>
    <!-- Hero: symbol-level provenance flow + PR / Action motif -->
    <section class="grid-bg relative overflow-hidden border-b border-line">
      <div class="glow relative mx-auto grid max-w-6xl items-center gap-12 px-5 py-20 sm:px-8 lg:grid-cols-[1.02fr_1fr] lg:py-28">
        <div class="relative z-10 flex flex-col items-start gap-6">
          <span class="eyebrow">Always current · open source</span>
          <h1 class="text-balance text-5xl font-extrabold sm:text-[64px] sm:leading-[0.99]">
            Documentation that <span class="gradient-text">keeps up</span> with your code.
          </h1>
          <p class="max-w-xl text-[18px] leading-relaxed text-muted">
            Change a function, and only the pages it touches regenerate - tracked at the symbol level. Run it locally,
            or as a GitHub Action that opens a PR with the changed pages and the reasons why. Nothing is pushed silently.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a href={site.repo} class="btn btn-primary">Get started</a>
            <a href="#how" class="btn btn-secondary">See the GitHub Action</a>
          </div>
          <div class="flex flex-wrap items-center gap-4 font-mono text-[12.5px] text-muted">
            <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-pass"></span> incremental by symbol</span>
            <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-brand-400"></span> opens a PR, never silent</span>
            <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-flag"></span> flagged, never silently wrong</span>
          </div>
        </div>

        <!-- Provenance flow mock -->
        <div class="relative z-10 float-slow">
          <div class="surface overflow-hidden">
            <div class="flex items-center justify-between border-b border-line px-5 py-4">
              <div class="flex items-center gap-2.5">
                <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
                  <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M5.5 8h5M8 5.5v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/></svg>
                </span>
                <h3 class="font-display text-[15px] font-semibold text-ink">Changed symbol → affected pages</h3>
              </div>
              <span class="font-mono text-[11px] text-muted">example</span>
            </div>

            <div class="flex flex-col gap-4 p-5">
              <!-- The changed symbol -->
              <div class="rounded-xl border border-flag/30 bg-flag/5 px-4 py-3">
                <div class="flex items-center justify-between">
                  <code class="font-mono text-[13px] text-ink">getSession(id)</code>
                  <span class="rounded-full bg-flag/12 px-2 py-0.5 font-mono text-[10.5px] font-medium text-flag">signature changed</span>
                </div>
                <p class="mt-1 font-mono text-[11.5px] text-muted">src/auth/session.ts</p>
              </div>

              <!-- Connector -->
              <div class="flex items-center gap-2 pl-1 font-mono text-[11px] text-muted">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3v8M8 11l-3-3M8 11l3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                provenance maps it to 2 pages
              </div>

              <!-- Affected pages: regenerate -->
              <ul class="flex flex-col gap-2">
                {
                  affected.map((a) => (
                    <li class="flex items-center gap-3 rounded-lg border border-line bg-canvas px-3.5 py-2.5">
                      <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-500/12 text-brand-600">
                        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8a5 5 0 018.5-3.5M13 8a5 5 0 01-8.5 3.5M11.5 4.5V2.5M11.5 4.5h-2M4.5 11.5v2M4.5 11.5h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                      <code class="font-mono text-[12.5px] text-ink">{a.page}</code>
                      <span class="ml-auto hidden text-right font-mono text-[10.5px] text-muted sm:block">{a.why}</span>
                      <span class="rounded-full bg-brand-500/10 px-2 py-0.5 font-mono text-[10px] font-medium text-brand-700">regenerate</span>
                    </li>
                  ))
                }
              </ul>

              <!-- Unchanged pages -->
              <div class="rounded-lg border border-dashed border-line px-3.5 py-2.5">
                <div class="flex items-center gap-2 text-[11.5px] text-muted">
                  <span class="flex h-4 w-4 items-center justify-center rounded-full bg-pass/12 text-pass">
                    <svg width="9" height="9" viewBox="0 0 12 12" fill="none"><path d="M2.5 6.2 5 8.7 9.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                  <span class="font-mono">{unchanged.length} other pages untouched - left exactly as they are</span>
                </div>
              </div>
            </div>

            <div class="border-t border-line bg-canvas px-5 py-3 text-[12.5px] text-muted">
              <span class="font-mono text-brand-600">docstube refresh</span> then runs a topology pass so the regenerated pages stay consistent with the rest.
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="border-b border-line bg-paper py-12">
      <RunsOn />
    </div>

    <!-- The core mechanism: incremental regeneration -->
    <Section
      eyebrow="The mechanism"
      title="Most docs rot because every change means rewriting everything."
      intro="docstube tracks which symbols each page depends on. When code changes, it detects the changed symbols, maps them to the pages that depend on them, regenerates only those, and runs a topology pass so the set stays internally consistent. The rest is left alone."
    >
      <div class="grid gap-5 md:grid-cols-3">
        <div class="surface hover-lift flex flex-col gap-3 p-6">
          <span class="font-mono text-[13px] font-semibold text-brand-500">01</span>
          <h3 class="font-display text-[17px] font-semibold text-ink">Detect changed symbols</h3>
          <p class="text-[14px] leading-relaxed text-muted">
            A structural map of your codebase pins each page to the functions, types, and endpoints it documents. A diff
            tells docstube exactly which symbols moved.
          </p>
        </div>
        <div class="surface hover-lift flex flex-col gap-3 p-6">
          <span class="font-mono text-[13px] font-semibold text-brand-500">02</span>
          <h3 class="font-display text-[17px] font-semibold text-ink">Map to affected pages</h3>
          <p class="text-[14px] leading-relaxed text-muted">
            Symbol-level provenance resolves each changed symbol to the pages that depend on it - usually two or three,
            not the whole site. Everything else is left untouched.
          </p>
        </div>
        <div class="surface hover-lift flex flex-col gap-3 p-6">
          <span class="font-mono text-[13px] font-semibold text-brand-500">03</span>
          <h3 class="font-display text-[17px] font-semibold text-ink">Regenerate, then reconcile</h3>
          <p class="text-[14px] leading-relaxed text-muted">
            Only the affected pages regenerate. A topology pass keeps cross-references, glossary terms, and links
            consistent - so a small change never quietly breaks a neighbour.
          </p>
        </div>
      </div>
    </Section>

    <!-- How it works (Steps) - prominent -->
    <Section id="how" eyebrow="How it works" title="Generate once, then stay in sync as you ship." tone="paper">
      <Steps />
    </Section>

    <!-- GitHub Action: the PR card -->
    <Section
      eyebrow="The GitHub Action"
      title="It opens a pull request - it never pushes silently."
      intro="Wire docstube into CI and every code change that touches your docs lands as a reviewable PR: the changed pages, and the reason each one changed. You stay in the loop; the docs stay current without anyone remembering to update them."
    >
      <div class="grid items-start gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <!-- Illustrative PR card -->
        <div class="surface overflow-hidden">
          <div class="flex items-center justify-between border-b border-line px-5 py-4">
            <div class="flex items-center gap-2.5">
              <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-pass/10 text-pass">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><circle cx="4" cy="4" r="1.8" stroke="currentColor" stroke-width="1.3"/><circle cx="4" cy="12" r="1.8" stroke="currentColor" stroke-width="1.3"/><circle cx="12" cy="12" r="1.8" stroke="currentColor" stroke-width="1.3"/><path d="M4 5.8v4.4M5.6 12h4.6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
              </span>
              <div>
                <h3 class="font-display text-[15px] font-semibold text-ink">docs: refresh 3 pages</h3>
                <p class="font-mono text-[11px] text-muted">docstube-bot wants to merge into <span class="text-ink-soft">main</span></p>
              </div>
            </div>
            <span class="rounded-full bg-pass/12 px-2.5 py-1 font-mono text-[10.5px] font-medium text-pass">Open · example</span>
          </div>

          <ul class="divide-y divide-line">
            {
              prPages.map((p) => (
                <li class="flex flex-col gap-1 px-5 py-3.5 sm:flex-row sm:items-center sm:gap-3">
                  <span class="flex items-center gap-2">
                    <span class="font-mono text-[12px] font-semibold text-pass">~</span>
                    <code class="font-mono text-[12.5px] text-ink">{p.file}</code>
                  </span>
                  <span class="text-[12.5px] text-muted sm:ml-auto sm:text-right">{p.reason}</span>
                </li>
              ))
            }
          </ul>

          <div class="flex flex-col gap-3 border-t border-line bg-canvas px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-2 text-[12.5px] text-muted">
              <span class="flex h-5 w-5 items-center justify-center rounded-full bg-pass/12 text-pass">
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2.5 6.2 5 8.7 9.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="font-mono">verifiers passed · 3 files changed</span>
            </div>
            <span class="font-mono text-[11.5px] text-muted">+128 −74</span>
          </div>
        </div>

        <!-- Why this matters -->
        <div class="flex flex-col gap-4">
          <div class="surface flex flex-col gap-2.5 p-6">
            <h3 class="font-display text-[17px] font-semibold text-ink">A diff you can actually review</h3>
            <p class="text-[14.5px] leading-relaxed text-ink-soft">
              Each changed page lands with the reason it changed, so review is a glance - not a re-read of the whole
              site. Approve it like any other PR.
            </p>
          </div>
          <div class="surface flex flex-col gap-2.5 p-6">
            <h3 class="font-display text-[17px] font-semibold text-ink">Verified before it ever reaches you</h3>
            <p class="text-[14.5px] leading-relaxed text-ink-soft">
              Samples type-check, imports and links resolve, diagrams render, and API references are matched to your
              compiler. Anything that can't be verified arrives <span class="font-semibold text-ink">flagged for review</span> - never silently wrong.
            </p>
          </div>
          <div class="surface-tint flex items-center gap-4 p-6">
            <span class="font-display text-[34px] font-bold leading-none gradient-text">↩</span>
            <p class="text-[14px] leading-relaxed text-ink-soft">
              Run the same thing locally first with <span class="font-mono text-brand-600">docstube refresh</span> - see the changed pages before any PR exists.
            </p>
          </div>
        </div>
      </div>
    </Section>

    <!-- Drift report -->
    <Section
      id="verify"
      eyebrow="What changed, and why"
      title="A drift report, before anything regenerates."
      intro="Before docstube touches a page, it shows you where your docs and your code have diverged - a changed signature, a removed endpoint, a new undocumented export. You see the blast radius first."
      tone="paper"
    >
      <div class="grid items-start gap-6 lg:grid-cols-[1fr_0.9fr]">
        <DriftReport />
        <div class="flex flex-col gap-4">
          <div class="surface flex flex-col gap-2.5 p-6">
            <h3 class="font-display text-[17px] font-semibold text-ink">Scoped to what actually moved</h3>
            <p class="text-[14.5px] leading-relaxed text-ink-soft">
              The report is driven by the same symbol-level provenance that scopes regeneration. A one-line change shows
              up as one or two affected pages - not a wall of noise.
            </p>
          </div>
          <div class="surface flex flex-col gap-2.5 p-6">
            <h3 class="font-display text-[17px] font-semibold text-ink">Nothing regenerates without a reason</h3>
            <p class="text-[14.5px] leading-relaxed text-ink-soft">
              Pages that still match their source are left exactly as they are. Less churn in your diffs, fewer surprises
              in review, and a site that only moves when the code does.
            </p>
          </div>
        </div>
      </div>
    </Section>

    <!-- Use cases - internal-team angle led -->
    <Section eyebrow="Built for teams" title="Onboarding docs for a codebase that changes every week.">
      <UseCases />
    </Section>

    <!-- Feature grid -->
    <Section eyebrow="Everything in the box" title="One open-source tool, the whole pipeline." tone="paper">
      <FeatureGrid />
    </Section>

    <!-- Compare -->
    <Section
      id="compare"
      eyebrow="Where it sits"
      title="Symbol-level updates, not a file-hash scan."
      intro="Other tools re-generate from scratch, scan by file hash, or rely on you to keep markdown in sync. docstube knows which symbols each page depends on - so updates are surgical, verified, and yours."
    >
      <CompareTable />
    </Section>

    <!-- Pricing + teams / governance note -->
    <Section
      id="pricing"
      eyebrow="Pricing"
      title="Free and complete on your machine. Cloud for the whole org."
      intro="The open-source tool is the entire product - CLI, web UI, GitHub Action, and verified incremental regeneration. The optional, usage-based Cloud tier is for teams that want every project's docs governed in one place."
      tone="paper"
    >
      <Pricing />

      <div class="surface mt-8 grid gap-6 p-6 sm:p-8 lg:grid-cols-[1.2fr_1fr]">
        <div class="flex flex-col gap-2.5">
          <span class="eyebrow">For engineering teams</span>
          <h3 class="font-display text-[20px] font-semibold text-ink">Keep every team's docs current - under one set of defaults.</h3>
          <p class="text-[14.5px] leading-relaxed text-ink-soft">
            Cloud aggregates docs across projects, adds an "Ask agent" and MCP that reach every repo, and gives teams
            company-wide defaults so each project's docs follow the same standards. It's optional and usage-based - the
            open-source tool already keeps a single repo current on its own.
          </p>
        </div>
        <ul class="grid grid-cols-1 gap-2.5 self-center sm:grid-cols-2 lg:grid-cols-1">
          {
            [
              { t: 'Company-wide defaults', d: 'one standard across every project' },
              { t: 'Governance', d: 'who can generate, refresh, and ship' },
              { t: 'Audit log', d: 'a record of what changed and why' },
              { t: 'Analytics', d: 'what readers actually use' }
            ].map((item) => (
              <li class="flex items-start gap-2.5 rounded-lg border border-line bg-canvas px-3.5 py-2.5">
                <svg class="mt-0.5 shrink-0 text-brand-500" width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M3 8.2 6.2 11.4 13 4.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span class="text-[13.5px] text-ink-soft"><span class="font-semibold text-ink">{item.t}</span> - {item.d}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </Section>

    <!-- Built for agents -->
    <Section eyebrow="Built for agents" title="Current context your own agents can read.">
      <BuiltForAgents />
    </Section>

    <!-- FAQ -->
    <Section id="faq" eyebrow="FAQ" title="The honest answers." tone="paper">
      <Faq />
    </Section>

    <FinalCta
      title="Stop maintaining docs by hand."
      sub="Point docstube at your repo once. After that, only the pages your code touches regenerate - locally or as a reviewable PR. Free and open-source."
    />
  </main>

  <Footer current={10} />
</Base>
