---
import { compareColumns, compareRows } from '../data/site.ts';
---

<div class="surface overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-left text-[13.5px]">
      <thead>
        <tr class="border-b border-line">
          <th class="px-5 py-4 font-display text-[13px] font-semibold uppercase tracking-wider text-muted">Capability</th>
          {
            compareRows.map((row) => (
              <th
                class={`px-4 py-4 text-center font-display text-[14px] font-semibold ${
                  row.self ? 'text-brand-600' : 'text-ink'
                }`}
              >
                {row.self ? (
                  <span class="inline-flex items-center gap-1.5">
                    <img src="/brand/docstube-icon.svg" alt="" width="18" height="18" />
                    docstube
                  </span>
                ) : (
                  row.tool
                )}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          compareColumns.map((col, i) => (
            <tr class="border-b border-line last:border-0">
              <td class="px-5 py-3.5 font-medium text-ink">{col}</td>
              {
                compareRows.map((row) => (
                  <td
                    class={`px-4 py-3.5 text-center ${
                      row.self ? 'bg-brand-50/60 font-semibold text-brand-700' : 'text-muted'
                    }`}
                  >
                    {row.values[i]}
                  </td>
                ))
              }
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>
<p class="mt-3 text-center text-[12.5px] text-muted">
  Incumbents lead on polish and maturity. docstube’s wedge is the combination: active generation, mechanical
  verification, your own compute, and output you own.
</p>
