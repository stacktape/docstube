---
import { nav as defaultNav, site, type NavLink } from '../data/site.ts';
import Logo from './Logo.astro';

type Props = {
  nav?: NavLink[];
};

const { nav = defaultNav } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-line/80 bg-canvas/80 backdrop-blur-xl">
  <div class="mx-auto flex h-[68px] max-w-6xl items-center justify-between gap-4 px-5 sm:px-8">
    <Logo size={38} />

    <nav class="hidden items-center gap-1 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-lg px-3 py-2 text-[14px] font-medium text-muted transition-colors hover:bg-brand-50 hover:text-ink"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2.5">
      <a
        href={site.repo}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-2 rounded-lg border border-line-strong bg-paper px-3 py-2 font-mono text-[13px] font-medium text-ink-soft shadow-soft transition hover:border-brand-300 hover:text-ink sm:inline-flex"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        stacktape/docstube
      </a>
      <a href={site.waitlist} class="btn btn-primary btn-sm">Join the waitlist</a>
    </div>
  </div>
</header>
