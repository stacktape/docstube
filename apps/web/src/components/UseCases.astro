---
import { useCases } from '../data/site.ts';
---

<div class="grid gap-5 md:grid-cols-3">
  {
    useCases.map((uc) => (
      <div class="surface hover-lift flex flex-col gap-3 p-6">
        <span class="w-fit rounded-full bg-brand-50 px-2.5 py-1 font-mono text-[11px] font-medium text-brand-700">
          {uc.audience}
        </span>
        <h3 class="font-display text-[18px] font-semibold text-ink">{uc.title}</h3>
        <p class="text-[14px] leading-relaxed text-muted">{uc.body}</p>
      </div>
    ))
  }
</div>
