---
import { site } from '../data/site.ts';
import Logo from './Logo.astro';
import VariantSwitcher from './VariantSwitcher.astro';

type Props = { current?: number; showVariants?: boolean };
const { current, showVariants = true } = Astro.props;

const columns = [
  {
    title: 'Product',
    links: [
      { label: 'How it works', href: '#how' },
      { label: 'Verification', href: '#verify' },
      { label: 'Compare', href: '#compare' },
      { label: 'Pricing', href: '#pricing' }
    ]
  },
  {
    title: 'Open source',
    links: [
      { label: 'GitHub', href: site.repo },
      { label: 'MIT license', href: site.repo },
      { label: 'Changelog', href: '#' },
      { label: 'Contributing', href: site.repo }
    ]
  },
  {
    title: 'For agents',
    links: [
      { label: 'llms.txt', href: '#' },
      { label: 'MCP server', href: '#' },
      { label: 'API references', href: '#' },
      { label: 'FAQ', href: '#faq' }
    ]
  }
];
---

<footer class="relative mt-24 border-t border-line bg-canvas">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <Logo size={36} />
        <p class="mt-4 max-w-xs text-[14px] text-muted">{site.tagline}</p>
        <a href={site.waitlist} class="btn btn-primary btn-sm mt-5">Join the waitlist</a>
      </div>
      {
        columns.map((col) => (
          <div>
            <h4 class="font-display text-[13px] font-semibold uppercase tracking-wider text-ink">{col.title}</h4>
            <ul class="mt-4 space-y-2.5">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-[14px] text-muted transition-colors hover:text-brand-600">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-line pt-6 text-[13px] text-muted sm:flex-row sm:items-center">
      <p>Open source · MIT · your code never leaves your machine.</p>
      <p class="font-mono text-[12px]">Generated by docstube ✦</p>
    </div>
  </div>

  {showVariants && <VariantSwitcher current={current} />}
</footer>
