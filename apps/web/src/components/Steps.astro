---
import { howItWorks } from '../data/site.ts';
---

<ol class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
  {
    howItWorks.map((s, i) => (
      <li class={`surface hover-lift relative flex flex-col gap-3 p-5 ${i === 0 ? 'lg:col-span-1' : ''}`}>
        <span class="font-mono text-[13px] font-semibold text-brand-500">{s.step}</span>
        <h3 class="font-display text-[17px] font-semibold text-ink">{s.title}</h3>
        <p class="text-[14px] leading-relaxed text-muted">{s.body}</p>
      </li>
    ))
  }
</ol>
