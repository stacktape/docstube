---
import { verifierChecks } from '../data/site.ts';

type Props = {
  command?: string;
  caption?: string;
  class?: string;
};

const { command = 'npx docstube generate', caption = 'auth/session.mdx', class: className = '' } = Astro.props;
---

<div class={`terminal w-full text-[13px] leading-relaxed ${className}`}>
  <div class="terminal-bar">
    <span class="terminal-dot" style="background:#f0716b"></span>
    <span class="terminal-dot" style="background:#f3c64a"></span>
    <span class="terminal-dot" style="background:#54c98b"></span>
    <span class="ml-2 font-mono text-[12px] text-[#6f8e8a]">docstube - {caption}</span>
  </div>
  <div class="p-4 sm:p-5">
    <div class="flex items-center gap-2">
      <span class="text-brand-300">❯</span>
      <span class="text-[#e7f5f2]">{command}</span>
    </div>
    <div class="mt-3 space-y-1.5">
      {
        verifierChecks.map((check, i) => (
          <div class="cascade-row flex items-center gap-2.5" style={`animation-delay:${0.5 + i * 0.28}s`}>
            {check.status === 'pass' ? (
              <span class="flex h-[18px] w-[18px] items-center justify-center rounded-full" style="background:rgba(21,160,107,0.16)">
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 6.2 5 8.7 9.5 3.5" stroke="#3ad99a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            ) : (
              <span class="flex h-[18px] w-[18px] items-center justify-center rounded-full" style="background:rgba(194,121,11,0.2)">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M6 2.2 10.4 9.6H1.6L6 2.2Z" stroke="#f0b454" stroke-width="1.4" stroke-linejoin="round" />
                  <path d="M6 5v2.1" stroke="#f0b454" stroke-width="1.4" stroke-linecap="round" />
                  <circle cx="6" cy="8.6" r="0.7" fill="#f0b454" />
                </svg>
              </span>
            )}
            <span class={check.status === 'pass' ? 'text-[#bfe0db]' : 'text-[#f0c98a]'}>{check.label}</span>
            <span class="ml-auto font-mono text-[11px]" style={check.status === 'pass' ? 'color:#3ad99a' : 'color:#f0b454'}>
              {check.status === 'pass' ? 'ok' : 'flagged'}
            </span>
          </div>
        ))
      }
    </div>
    <div class="cascade-row mt-3.5 flex items-center gap-2 border-t border-[#16302e] pt-3 text-[#9fc4be]" style="animation-delay:3s">
      <span class="text-brand-300">❯</span>
      <span>7 pages shipped · 1 flagged for review</span>
      <span class="caret ml-0.5 inline-block h-[14px] w-[7px] bg-brand-300 align-middle"></span>
    </div>
  </div>
</div>
