{
  "name": "docstube",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacktape/docstube.git",
    "directory": "apps/cli"
  },
  "bin": {
    "docstube": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "local-ui"
  ],
  "type": "module",
  "exports": {
    ".": {
      "docstube-source": "./src/cli.ts",
      "types": "./dist/cli.d.mts",
      "import": "./dist/cli.mjs"
    }
  },
  "scripts": {
    "build": "pnpm --dir ../.. run build:cli",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@clack/prompts": "^1.5.1",
    "@docstube/core": "workspace:*",
    "@docstube/verifiers": "workspace:*",
    "@yao-pkg/pkg": "^6.20.0",
    "citty": "^0.2.2",
    "yaml": "^2.9.0"
  }
}
