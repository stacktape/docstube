{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    ".docstube/**",
    ".docstube-build/**",
    "pnpm-lock.yaml",
    "PLAN.md",
    "BUSINESS.md"
  ],
  "insertFinalNewline": true,
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "none"
}
